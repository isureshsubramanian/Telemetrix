<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!--
    Central Package Management (Directory.Packages.props) requires either a single
    package source or explicit package source mapping; otherwise NuGet raises NU1507.
    We clear any inherited sources, use nuget.org only, and map every package to it.
    Add a private feed here (plus a matching <packageSource> mapping) if you need one.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

</configuration>
